# Chat LLM provider: "google" (default) | "anthropic" | "openai"
LLM_PROVIDER=google

# Google Gemini — REQUIRED ALWAYS: used for the RAG embeddings, and for chat
# when LLM_PROVIDER=google. Free key at https://aistudio.google.com/apikey
# Prefer gemini-2.5-flash: chat disables thinking on it (sub-second first
# token). Gemini 3+ models cannot turn thinking off (only capped at "low"),
# which costs several extra seconds per answer.
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Optional — only needed if you switch the chat provider away from Google.
# Embeddings always use Google regardless of these.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Public portfolio links and canonical URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_URL=https://github.com/DanielTrindade
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_RESUME_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Private knowledge-base workspace password (used only to create a server session)
ADMIN_PASSWORD=

# Minimum cosine similarity for RAG retrieval (0 = return everything, default 0.3).
# Lower it if too few results are returned; raise it to reduce noise.
RAG_MATCH_THRESHOLD=0.3

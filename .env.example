# Chat LLM provider: "google" (default) | "anthropic" | "openai"
LLM_PROVIDER=google

# Google Gemini — REQUIRED ALWAYS: used for the RAG embeddings, and for chat
# when LLM_PROVIDER=google. Free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Optional — only needed if you switch the chat provider away from Google.
# Embeddings always use Google regardless of these.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin upload secret
ADMIN_PASSWORD=
